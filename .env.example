# Server
PORT=5000
NODE_ENV=development

# MongoDB
# IMPORTANT: Replace this with your own MongoDB connection string.
# Example (local):        mongodb://127.0.0.1:27017/running-tracker
# Example (Atlas cloud):  mongodb+srv://<username>:<password>@cluster0.mongodb.net/running-tracker
MONGO_URI=your_mongodb_connection_string_here

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Cookie
COOKIE_EXPIRES_IN_DAYS=7

# CORS
CLIENT_URL=http://localhost:3000
